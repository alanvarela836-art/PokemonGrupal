package com.pokemon;

/**
 * Declaramos nombre, y los puntos de salud del jugador, creamos un constructor
 * y los metodos get y set para poder acceder a los atributos de la clase, y su
 * método de validación.
 */
public class Entrenador {

    private String nombre;
    private int VidaArena;

    public Entrenador(String nombre, int VidaArena) {
        this.nombre = nombre;
        this.VidaArena = VidaArena;
    }

    public String getNombre() {
        return nombre;
    }

    public void setNombre(String nombre) {
        this.nombre = nombre;
    }

    public int getVidaArena() {
        return VidaArena;
    }

    public void recibirDaño(int cantidad) {
        // Restamos el daño reibido a nuestra vida actual.
        this.VidaArena -= cantidad;

        // Validamos que la vida no sea menor a 0.
        if (this.VidaArena < 0) {
            this.VidaArena = 0;
        }
    }

}
