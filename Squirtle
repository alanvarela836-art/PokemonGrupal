package com.trabajogrupalpokemonarena;

public final class Squirtle extends Pokemon implements AccionCombate {
    public Squirtle(String nombre, int hp) {
        super("Squirtle", 120);
    }

    @Override
    public void ejecutar(Pokemon objetivo) {
        System.out.println(getNombre() + " da un golpe de caparazón a  " + objetivo.getNombre());
        objetivo.setHp(objetivo.getHp() - 12);
        System.out.println(objetivo.getNombre() + " ahora tiene " + objetivo.getHp() + " HP.");
    }
    //Habilidad Exclusiva de Squirtle que le resta 30 HP al objetivo y lo deja empapado
    public void hidrobomba(Pokemon objetivo) {
        System.out.println("¡¡HIDROBOMBA DE PRESIÓN DE " + getNombre() + "!!");
        objetivo.setHp(objetivo.getHp() - 30);
        System.out.println(objetivo.getNombre() + " ES EMPUJADO!! queda empapado y con " + objetivo.getHp() + " HP.");
    }
}
